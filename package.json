{
  "name": "honotreez",
  "description": "honotreez is boilerplate for backend development with Hono, Drizzle ORM, and Better Auth.",
  "scripts": {
    "dev": "bun run --bun --hot src/index.ts",
    "start": "bun run src/index.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "bunx oxlint . --tsconfig ./tsconfig.json --type-aware",
    "lint:fix": "bunx oxlint . --tsconfig ./tsconfig.json --type-aware --fix --fix-suggestions",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun --bun ./src/db/seeders/seed.ts",
    "db:reset": "bun --bun ./src/db/seeders/reset.ts",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@t3-oss/env-core": "^0.13.10",
    "better-auth": "^1.5.3",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "nanoid": "^5.1.6",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsx": "^4.21.0"
  }
}
